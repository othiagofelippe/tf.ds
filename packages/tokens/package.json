{
  "name": "@tfds/tokens",
  "version": "0.0.1",
  "description": "Design tokens for tf.ds — W3C DTCG format",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./css": "./dist/css/index.css",
    "./css/themes/*": "./dist/css/themes/*.css",
    "./js": "./dist/js/index.js",
    "./js/themes/*": "./dist/js/themes/*.js",
    "./tailwind": "./dist/tailwind/preset.js",
    "./json/*": "./dist/json/*.json",
    "./types": "./dist/types/token-names.d.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js --watch",
    "lint": "node scripts/lint-tokens.mjs",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "verify-pack": "node ../../scripts/verify-pack.mjs"
  },
  "devDependencies": {
    "@tfds/tsconfig": "workspace:*",
    "@types/node": "^25.0.0",
    "style-dictionary": "^4.3.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
